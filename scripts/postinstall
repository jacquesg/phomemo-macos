#!/bin/bash
#
# Post-installation script for phomemo-macos CUPS driver.
#
# Restarts CUPS so it picks up the newly installed backends,
# filters, and PPDs.  Printers must be added manually — see the
# README for instructions.
#

LOGGER="/usr/bin/logger -t phomemo-postinstall"

$LOGGER "Starting Phomemo driver post-installation"

/bin/launchctl kickstart -k system/org.cups.cupsd 2>/dev/null || true

$LOGGER "Post-installation complete"
exit 0
